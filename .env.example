# ---------------------------------------------------------------
# FLEET B LOGISTICS — email configuration
# Copy to .env.local (dev) or set in your hosting dashboard (prod).
# Until these are set, form submissions are logged, not emailed.
# ---------------------------------------------------------------

# SMTP provider (e.g. Gmail app password, Brevo, Resend SMTP, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=fleetblogistics@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="Fleet B Logistics" <fleetblogistics@gmail.com>

# Where internal notifications go (defaults to company email)
NOTIFY_EMAIL=fleetblogistics@gmail.com

# Public site URL (used in emails + SEO)
NEXT_PUBLIC_SITE_URL=https://www.fleetblogistics.com
